# ============================================
# Multi-Agent Intelligence System
# Copy to .env and fill in your values
# ============================================

# Database (Railway provides this automatically)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/intelligence

# Redis (Railway provides this automatically)
REDIS_URL=redis://localhost:6379

# LLM API Keys (REQUIRED)
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Data Source API Keys (get free keys from each provider)
FRED_API_KEY=              # https://fred.stlouisfed.org/docs/api/api_key.html
NEWSDATA_API_KEY=          # https://newsdata.io/register
TWELVE_DATA_API_KEY=       # https://twelvedata.com/register

# API Authentication (change this!)
API_KEY=changeme

# LLM Model Configuration (defaults are fine)
# CLAUDE_SONNET_MODEL=claude-sonnet-4-20250514
# CLAUDE_HAIKU_MODEL=claude-haiku-4-5-20251001
# GPT4O_MODEL=gpt-4o

# Operational
LOG_LEVEL=INFO
ENVIRONMENT=development

# Confidence Capping (from Part 4 of brief)
# MIN_EVIDENCE_INTEGRITY=0.50
# CONFIDENCE_CAP_MULTIPLIER=0.40

# Frontend (set in Railway or docker-compose for the frontend service)
# NEXT_PUBLIC_API_URL=http://localhost:8000    # URL of the API server
# NEXT_PUBLIC_API_KEY=changeme                 # Must match API_KEY above
